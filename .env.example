# USCIS monitor runtime configuration
# Copy this file to .env and fill values.

TELEGRAM_BOT_TOKEN=
POLL_INTERVAL=300
USCIS_API_MODE=auto
CUSTOM_ENDPOINT=
USCIS_LOGIN_URL=https://my.uscis.gov
USCIS_DASHBOARD_URL=https://my.uscis.gov/my-account/dashboard/info
USCIS_PUBLIC_API=https://egov.uscis.gov/case-status/api/cases/{receipt_number}
USCIS_MY_API=https://my.uscis.gov/api/cases/{receipt_number}
APP_DIR=~/.uscis_monitor
DB_PATH=~/.uscis_monitor/data.db
SESSION_PATH=~/.uscis_monitor/session.enc
KEY_PATH=~/.uscis_monitor/.fernet_key
LOG_PATH=~/.uscis_monitor/monitor.log

# Comma-separated Telegram user IDs that may run /addaccount (opens Chrome on host).
# Find your ID by messaging @userinfobot on Telegram. Leave empty to allow all users.
# Example: ALLOWED_TELEGRAM_IDS=123456789,987654321
ALLOWED_TELEGRAM_IDS=

# Automated USCIS login (optional — enables hands-free /relogin and refresh)
# Primary account:
USCIS_EMAIL=
USCIS_PASSWORD=
# 16-character Gmail App Password (spaces OK). Same inbox as USCIS_EMAIL.
# Create at: Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=
# Named account (example: boris):
# USCIS_EMAIL_BORIS=
# USCIS_PASSWORD_BORIS=
# GMAIL_APP_PASSWORD_BORIS=
# Immigration-style aliases for primary also work: USCIS_EMAIL_1, etc.
